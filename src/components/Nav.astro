---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  active?: 'home' | 'blog' | 'projects' | 'about' | 'tags';
}
const { active } = Astro.props;
---
<nav class="nav" aria-label="Primary">
  <a href="/" aria-current={active === 'home' ? 'page' : undefined}>home</a>
  <a href="/blog" aria-current={active === 'blog' ? 'page' : undefined}>blog</a>
  <a href="/projects" aria-current={active === 'projects' ? 'page' : undefined}>projects</a>
  <a href="/about" aria-current={active === 'about' ? 'page' : undefined}>about</a>
  <a href="/tags" aria-current={active === 'tags' ? 'page' : undefined}>tags</a>
  <ThemeToggle />
</nav>
