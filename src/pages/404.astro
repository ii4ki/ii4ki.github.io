---
import Base from '../layouts/Base.astro';
---
<Base
  title="404 — file not found"
  description="The thing you were looking for is not here."
  path="404"
  pathMeta="exit 127"
>
  <section class="notfound">
    <div class="prompt-line"><span class="prompt">$</span> cat <span style="color:var(--accent)">/var/www<span style="color:var(--dim)">$REQUEST_PATH</span></span></div>
    <div class="err">cat: no such file or directory</div>
    <div class="prompt-line"><span class="prompt">$</span> echo $?</div>
    <div style="color:var(--text)">404</div>
    <div class="hint" style="margin-top:24px">the thing you were looking for is not here. it may have moved, or it may never have existed. either way, the path returned nothing.</div>
    <div class="hint">try one of these instead:</div>
    <div class="tree" style="margin-top:8px"><span class="branch">├──</span> <a href="/">/ </a>
<span class="branch">├──</span> <a href="/blog">/blog</a>
<span class="branch">├──</span> <a href="/projects">/projects</a>
<span class="branch">└──</span> <a href="/about">/about</a></div>
  </section>
</Base>
