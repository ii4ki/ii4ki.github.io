---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTags } from '../../lib/tags';

const posts = (await getCollection('blog', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tags = await getAllTags();

const years = posts.map(p => p.data.pubDate.getFullYear());
const pathMeta = posts.length > 0
  ? `${posts.length} posts · ${Math.max(...years)} → ${Math.min(...years)}`
  : `${posts.length} posts`;
---
<Base
  title="blog — ii4ki"
  description="All posts. Chronological."
  path="blog"
  pathMeta={pathMeta}
  activeNav="blog"
>
  <section class="section">
    <div class="section-header">
      <h2>blog</h2>
      {tags.length > 0 && (
        <span class="more">
          filter:&nbsp;
          {tags.map((tag, i) => (
            <>
              <a href={`/tags/${tag}`} style="color:var(--accent);border-bottom-color:transparent">#{tag}</a>
              {i < tags.length - 1 && ' '}
            </>
          ))}
        </span>
      )}
    </div>

    <ul class="post-list">
      {posts.map(post => (
        <li>
          <PostCard
            href={`/blog/${post.id}`}
            date={post.data.pubDate}
            title={post.data.title}
            meta={post.data.tags.map(t => `#${t}`).join(' ')}
          />
        </li>
      ))}
    </ul>
  </section>
</Base>
