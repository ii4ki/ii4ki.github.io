---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Cursor from '../components/Cursor.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const buildDate = new Date().toISOString().slice(0, 10);

const posts = (await getCollection('blog', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const featured = (await getCollection('projects', p => p.data.featured))
  .sort((a, b) => a.data.order - b.data.order);
---
<Base
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  path="site"
  pathMeta={`last build: ${buildDate}`}
  activeNav="home"
>
  <section class="hero" aria-label="Identity">
    <div class="hero-stack">
      <span class="line"><span class="prompt">$</span> whoami</span>
      <span class="line"><span class="arrow">&gt;</span> vibe coder. automations guru. developer.</span>
      <span class="line"><span class="arrow">&gt;</span> building small tools that do one thing well.<Cursor /></span>
    </div>
  </section>

  <section class="section" aria-labelledby="recent">
    <div class="section-header">
      <h2 id="recent">recent posts</h2>
      <a class="more" href="/blog">all posts &nbsp;→</a>
    </div>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <PostCard
            href={`/blog/${post.id}`}
            date={post.data.pubDate}
            title={post.data.title}
            meta={post.data.tags.slice(0, 2).map(t => `#${t}`).join(' · ')}
          />
        </li>
      ))}
    </ul>
  </section>

  <section class="section" aria-labelledby="featured">
    <div class="section-header">
      <h2 id="featured">featured projects</h2>
      <a class="more" href="/projects">all projects &nbsp;→</a>
    </div>
    <div class="featured-list">
      {featured.map(p => (
        <a class="featured-card" href="/projects">
          <span class={`status tag-bracket ${p.data.status.toLowerCase()}`}>[{p.data.status}]</span>
          <span>
            <span class="name">{p.data.name}</span>
            <p class="desc">{p.data.description}</p>
          </span>
          <span class="arrow">→</span>
        </a>
      ))}
    </div>
  </section>
</Base>
