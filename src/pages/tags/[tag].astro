---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTags } from '../../lib/tags';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = (await getCollection('blog', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allPosts.filter(p => p.data.tags.includes(tag!));
const otherTags = (await getAllTags()).filter(t => t !== tag);
---
<Base
  title={`#${tag} — ii4ki`}
  description={`All posts tagged #${tag}.`}
  path={`tags/${tag}`}
  pathMeta={`grep -r '#${tag}' blog/`}
  activeNav="blog"
>
  <section class="section">
    <div class="tag-intro">
      <span class="hash">#</span>{tag}
      <span class="count">// {posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
    </div>

    <ul class="post-list">
      {posts.map(post => (
        <li>
          <PostCard
            href={`/blog/${post.id}`}
            date={post.data.pubDate}
            title={post.data.title}
            meta={post.data.tags.filter(t => t !== tag).map(t => `#${t}`).join(' ')}
          />
        </li>
      ))}
    </ul>

    {otherTags.length > 0 && (
      <p style="margin-top:32px;font-size:var(--fs-sm);color:var(--muted)">
        other tags:
        {otherTags.map(t => (
          <a href={`/tags/${t}`} style="color:var(--accent);margin-left:12px">#{t}</a>
        ))}
      </p>
    )}
  </section>
</Base>
